{
  "name": "@tb-dev/vue-components",
  "version": "7.1.18",
  "description": "Vue components",
  "license": "MIT",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.2",
  "funding": "https://github.com/sponsors/ferreira-tb",
  "author": {
    "name": "Andrew Ferreira",
    "email": "andrew.shien2@gmail.com",
    "url": "https://github.com/ferreira-tb"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferreira-tb/vue-components.git"
  },
  "bugs": {
    "url": "https://github.com/ferreira-tb/vue-components/issues"
  },
  "keywords": [
    "vue",
    "components"
  ],
  "scripts": {
    "build": "vite build",
    "format": "dprint fmt",
    "lint": "eslint . --config eslint.config.js",
    "release": "pnpm run build && pnpm publish",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@lucide/vue": "^1.11.0",
    "@tanstack/vue-table": "^8.21.3",
    "@tb-dev/utils": "^7.3.19",
    "@tb-dev/vue": "^4.0.21",
    "@tb-dev/vue-sonner": "^1.0.0",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tb-dev/eslint-config": "^10.0.8",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vue-tsc": "^3.2.7"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {

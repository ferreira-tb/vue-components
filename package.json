{
  "name": "@tb-dev/vue-components",
  "version": "7.1.24",
  "description": "Vue components",
  "license": "MIT",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@11.5.2",
  "funding": "https://github.com/sponsors/ferreira-tb",
  "author": {
    "name": "Andrew Ferreira",
    "email": "andrew.shien2@gmail.com",
    "url": "https://github.com/ferreira-tb"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferreira-tb/vue-components.git"
  },
  "bugs": {
    "url": "https://github.com/ferreira-tb/vue-components/issues"
  },
  "keywords": ["vue", "components"],
  "scripts": {
    "build": "vite build",
    "format": "dprint fmt",
    "lint": "eslint . --config eslint.config.js",
    "release": "pnpm run build && pnpm publish",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@tb-dev/utils": "^7.3.23",
    "@tb-dev/vue": "^4.0.25",
    "@tb-dev/vue-sonner": "^1.0.5",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.9.9",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul-vue": "^0.4.1",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tb-dev/eslint-config": "^10.0.12",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/language-core": "^3.3.3",
    "eslint": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "unplugin-dts": "^1.0.2",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.3"
  },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style": {
      "import": "./dist/index.css"
    }
  }
